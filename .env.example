# Firebase (client SDK — safe to expose in SPA)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: callable URL or Netlify/Vercel route that returns presigned S3 PUT URLs (recommended for production)
VITE_S3_PRESIGN_URL=

# AWS S3 — optional dev-only direct upload (prefer presigned URLs / IAM roles server-side in production)
VITE_AWS_REGION=eu-west-2
VITE_AWS_S3_BUCKET=
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=

# Axios default base (optional)
VITE_API_BASE_URL=

# WhatsApp deep link (digits only, country code included)
VITE_WHATSAPP_NUMBER=447520637686
